{
  "tables": [
    {
      "name": "users",
      "columns": [
        { "name": "id", "type": "INTEGER", "constraints": "PRIMARY KEY AUTOINCREMENT" },
        { "name": "username", "type": "TEXT", "constraints": "NOT NULL UNIQUE" },
        { "name": "password_hash", "type": "TEXT", "constraints": "NOT NULL" },
        { "name": "created_at", "type": "TEXT", "constraints": "NOT NULL DEFAULT (datetime('now'))" }
      ]
    },
    {
      "name": "boards",
      "columns": [
        { "name": "id", "type": "INTEGER", "constraints": "PRIMARY KEY AUTOINCREMENT" },
        { "name": "user_id", "type": "INTEGER", "constraints": "NOT NULL REFERENCES users(id)" },
        { "name": "title", "type": "TEXT", "constraints": "NOT NULL DEFAULT 'My Board'" },
        { "name": "created_at", "type": "TEXT", "constraints": "NOT NULL DEFAULT (datetime('now'))" }
      ]
    },
    {
      "name": "columns",
      "columns": [
        { "name": "id", "type": "INTEGER", "constraints": "PRIMARY KEY AUTOINCREMENT" },
        { "name": "board_id", "type": "INTEGER", "constraints": "NOT NULL REFERENCES boards(id)" },
        { "name": "title", "type": "TEXT", "constraints": "NOT NULL" },
        { "name": "position", "type": "INTEGER", "constraints": "NOT NULL" }
      ]
    },
    {
      "name": "cards",
      "columns": [
        { "name": "id", "type": "INTEGER", "constraints": "PRIMARY KEY AUTOINCREMENT" },
        { "name": "column_id", "type": "INTEGER", "constraints": "NOT NULL REFERENCES columns(id)" },
        { "name": "title", "type": "TEXT", "constraints": "NOT NULL" },
        { "name": "details", "type": "TEXT", "constraints": "NOT NULL DEFAULT ''" },
        { "name": "position", "type": "INTEGER", "constraints": "NOT NULL" },
        { "name": "created_at", "type": "TEXT", "constraints": "NOT NULL DEFAULT (datetime('now'))" }
      ]
    }
  ],
  "pragmas": [
    "PRAGMA journal_mode=WAL",
    "PRAGMA foreign_keys=ON"
  ]
}
